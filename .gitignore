ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv. But in a library, it's usually ignored.
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if lock is used, it might include platform-specific dependencies.
#   Pipfile.lock

# poetry
#   Poetry uses poetry.lock to ensure reproducible builds.
#   poetry.lock

# pdm
#   PDM stores dependencies in __pypackages__
__pypackages__/

